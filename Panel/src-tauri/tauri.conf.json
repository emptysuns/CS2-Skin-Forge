{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "CS2-Skin-Mod",
  "version": "1.5.11",
  "identifier": "com.cs2skinmod.panel",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "deb", "dmg"],
    "resources": [
      "../../addons/counterstrikesharp/plugins/PlayerSkinMod/PlayerSkinMod.json",
      "../../addons/counterstrikesharp/plugins/PlayerSkinMod/skins_en.json",
      "../../addons/counterstrikesharp/plugins/PlayerSkinMod/PlayerSkinMod.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "app": {
    "windows": [
      {
        "title": "CS2 Skin Mod v1.5.11",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {}
  }
}
